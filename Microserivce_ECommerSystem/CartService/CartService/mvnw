# ----------------------------------------------------------------------------
# Maven Start Up Batch script
# ----------------------------------------------------------------------------

# set -e

BASE_DIR=$(dirname "$(readlink -f "$0")" || echo $(dirname "$0"))
MAVEN_PROJECTBASEDIR=${MAVEN_BASEDIR:-"$BASE_DIR"}
MAVEN_SCRIPT_DIR="$MAVEN_PROJECTBASEDIR/.mvn"

# maven.cmd, maven.sh
if [ -f "$MAVEN_SCRIPT_DIR/maven.cmd" ]; then
    "$MAVEN_SCRIPT_DIR/maven.cmd" "$@"
    exit $?
elif [ -f "$MAVEN_SCRIPT_DIR/maven.sh" ]; then
    sh "$MAVEN_SCRIPT_DIR/maven.sh" "$@"
    exit $?
else
    # try to download maven and run
    echo "Maven not found in $MAVEN_SCRIPT_DIR"
    echo "Please ensure Maven is installed and configured properly"
    exit 1
fi

